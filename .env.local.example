# Contact form → Google Apps Script webhook (see scripts/gmail-contact-form.js)
CONTACT_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXXXXXX/exec
CONTACT_WEBHOOK_SECRET=replace-with-a-long-random-string

# Supabase — CRM / admin backend
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
# Server-only secret key (sb_secret_...), used from Milestone 2 onward
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
